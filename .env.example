# Copy to ".env" and fill in. These EXPO_PUBLIC_* values are bundled into the
# app and are NOT secrets (Mapbox public token + Supabase anon key are meant to
# ship in clients). Never put a Mapbox SECRET (sk.*) token or a Supabase
# service_role key in here.

# Mapbox public access token (starts with pk.)
EXPO_PUBLIC_MAPBOX_TOKEN=

# Optional: custom dark style URL (defaults to mapbox://styles/mapbox/dark-v11)
EXPO_PUBLIC_MAPBOX_STYLE=

# Supabase project (Project Settings -> API)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
