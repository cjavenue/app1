# Copy to ".env" and fill in. These EXPO_PUBLIC_* values are bundled into the
# app and are NOT secrets (Stadia API key + Supabase publishable key are meant
# to ship in clients). Never put a Supabase SECRET key in here.

# Stadia Maps API key (free, no credit card). https://client.stadiamaps.com/
EXPO_PUBLIC_STADIA_API_KEY=

# Optional: override the map style URL (defaults to Alidade Smooth Dark)
EXPO_PUBLIC_MAP_STYLE=

# Supabase project (Project Settings -> API)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
